# 复制为 .env 后，docker compose 会自动读取。
# 默认使用 Docker Hub 官方镜像；如果 Docker Desktop 拉取 Docker Hub 超时，可以改用下面的国内镜像示例。

MYSQL_IMAGE=mysql:8.0
REDIS_IMAGE=redis:7-alpine
NACOS_IMAGE=nacos/nacos-server:v3.2.2
XXL_JOB_ADMIN_IMAGE=xuxueli/xxl-job-admin:2.4.1
JAVA17_IMAGE=eclipse-temurin:17-jre
JAVA21_IMAGE=eclipse-temurin:21-jre
NODE_IMAGE=node:20-alpine
NGINX_IMAGE=nginx:1.27-alpine

# 国内镜像示例：
# MYSQL_IMAGE=docker.m.daocloud.io/library/mysql:8.0
# REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine
# NACOS_IMAGE=docker.m.daocloud.io/nacos/nacos-server:v3.2.2
# XXL_JOB_ADMIN_IMAGE=docker.m.daocloud.io/xuxueli/xxl-job-admin:2.4.1
# JAVA17_IMAGE=docker.m.daocloud.io/library/eclipse-temurin:17-jre
# JAVA21_IMAGE=docker.m.daocloud.io/library/eclipse-temurin:21-jre
# NODE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
# NGINX_IMAGE=docker.m.daocloud.io/library/nginx:1.27-alpine

# javachain 可选：
# DEEPSEEK_API_KEY=
# DASHSCOPE_API_KEY=
