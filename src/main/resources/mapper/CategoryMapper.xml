<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.oa.system.mapper.CategoryMapper">

    <resultMap id="BaseResultMap" type="com.oa.system.entity.Category">
        <id column="id" property="id"/>
        <result column="category_name" property="categoryName"/>
        <result column="category_code" property="categoryCode"/>
        <result column="sort" property="sort"/>
        <result column="status" property="status"/>
        <result column="parent_id" property="parentId"/>
        <result column="remark" property="remark"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectCategoryPage" resultMap="BaseResultMap">
        SELECT * FROM sys_category
        ORDER BY sort ASC, id ASC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countCategoryPage" resultType="long">
        SELECT COUNT(*) FROM sys_category
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM sys_category WHERE id = #{id}
    </select>

    <select id="selectByCategoryCode" resultMap="BaseResultMap">
        SELECT * FROM sys_category WHERE category_code = #{categoryCode}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM sys_category ORDER BY sort ASC, id ASC
    </select>

    <select id="selectByParentId" resultMap="BaseResultMap">
        SELECT * FROM sys_category WHERE parent_id = #{parentId} ORDER BY sort ASC, id ASC
    </select>

    <select id="existsByCategoryCode" resultType="boolean">
        SELECT COUNT(*) > 0 FROM sys_category WHERE category_code = #{categoryCode}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_category (category_name, category_code, sort, status, parent_id, remark, create_by, create_time)
        VALUES (#{categoryName}, #{categoryCode}, #{sort}, #{status}, #{parentId}, #{remark}, #{createBy}, #{createTime})
    </insert>

    <update id="update">
        UPDATE sys_category
        SET category_name = #{categoryName},
            category_code = #{categoryCode},
            sort = #{sort},
            status = #{status},
            parent_id = #{parentId},
            remark = #{remark},
            update_by = #{updateBy},
            update_time = #{updateTime}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_category WHERE id = #{id}
    </delete>

</mapper>
